# TransitHub Environment Variables
# Copy this file to .env and fill in values

# === PostgreSQL ===
POSTGRES_DB=transithub
POSTGRES_USER=transithub
POSTGRES_PASSWORD=TransitHub@2024
POSTGRES_PORT=5432

# === MongoDB ===
MONGO_INITDB_DATABASE=transithub
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=Mongo@2024
MONGO_PORT=27017

# === Redis ===
REDIS_PASSWORD=Redis@2024
REDIS_PORT=6379

# === Kafka ===
KAFKA_BROKER_ID=1
KAFKA_PORT=9092
KAFKA_INTERNAL_PORT=29092
KAFKA_ZOOKEEPER_PORT=2181

# === JWT ===
JWT_SECRET=TransitHub_JWT_Min32Char_SecretKey_2024
JWT_ACCESS_EXPIRY=900       # 15 minutes in seconds
JWT_REFRESH_EXPIRY=604800   # 7 days in seconds

# === AWS / LocalStack ===
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
AWS_S3_ENDPOINT=http://localhost:4566
AWS_S3_BUCKET=transithub-documents-dev
LOCALSTACK_PORT=4566

# === Elasticsearch ===
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_HOST=localhost

# === Spring Profiles ===
SPRING_PROFILES_ACTIVE=dev

# === Service URLs ===
EUREKA_URI=http://localhost:8761/eureka
CONFIG_SERVER_URI=http://localhost:8888
API_GATEWAY_URL=http://localhost:8080

# === Monitoring ===
ZIPKIN_PORT=9411
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
KAFKA_UI_PORT=8090
PGADMIN_PORT=5050
MONGO_EXPRESS_PORT=8091

# === GitHub (for CI/CD, fill in when account is ready) ===
# GITHUB_USERNAME=your-username
# GITHUB_TOKEN=your-token

# === AWS Production (fill in when AWS account is created) ===
# AWS_ACCOUNT_ID=123456789012
# AWS_EKS_CLUSTER_NAME=transithub-cluster
# RDS_ENDPOINT=transithub.c9abcdefghij.ap-south-1.rds.amazonaws.com
# OPENSEARCH_ENDPOINT=https://search-transithub-xxx.ap-south-1.es.amazonaws.com
